# ============================================================
# BIZ.MKT.OS — Environment variables example
# Copy file này thành `.env` (hoặc `.env.local`) và điền key thật.
# KHÔNG commit `.env` vào git (đã có trong .gitignore mặc định của Claude Code).
# ============================================================

# ------------------------------------------------------------
# ElevenLabs — Text-to-Speech (skill: mkt-elevenlabs-tts-to-mp3)
# Dùng cho cả 2 pipeline 9:16 và 16:9 ở Phase 1 (script -> voiceover MP3)
# Lấy key tại: https://elevenlabs.io/app/settings/api-keys
# ------------------------------------------------------------
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here

# Voice ID mặc định (Hoàng's brand voice). Đổi nếu muốn dùng voice khác.
# Tham khảo voice library: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=K7ewtjKRNtwwt3lKQ6M0

# ------------------------------------------------------------
# HeyGen — Avatar lip-sync video (skill: heygen-mp3-to-mp4)
# Dùng cho Phase 2 (MP3 -> avatar MP4) của cả 2 orchestrator
# Lấy key tại: https://app.heygen.com/settings/api
# ------------------------------------------------------------
HEYGEN_API_KEY=your_heygen_api_key_here

# Danh sách avatar look ID (comma-separated). Skill sẽ random pick 1 trong số này.
# Lấy ID từ HeyGen Studio -> chọn avatar -> URL hoặc API GET /v2/avatars
# Ví dụ: HEYGEN_AVATAR_LOOKS=66e75e22e6584bbdaa56a19088286dc8,abc123...
HEYGEN_AVATAR_LOOKS=avatar_look_id_1,avatar_look_id_2

# (Tuỳ chọn) HeyGen voice ID — chỉ dùng nếu force MCP path qua HeyGen TTS
# thay vì upload MP3 từ ElevenLabs. Để trống nếu pipeline mặc định (ElevenLabs).
HEYGEN_VOICE_ID=

# ------------------------------------------------------------
# (Tuỳ chọn) Gemini — Nano Banana Pro image gen fallback
# Skill: mkt-plan-short-video-edit-16-9 (Phase 3.5 cream-paper infographic)
# Dùng khi AI33 trả `temporary_model_error` -> fallback `-p nano`.
# Lấy key tại: https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# (Tuỳ chọn) OpenAI — chỉ cần nếu dùng Whisper API cloud thay vì local
# Skill mkt-ai-video-extract-srt-segment mặc định dùng `whisper` CLI local
# (cài: pip install openai-whisper), không cần key. Để trống nếu dùng local.
# ------------------------------------------------------------
OPENAI_API_KEY=
